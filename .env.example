# NetBackup paths
NETBACKUP_DB=netbackup.db
NETBACKUP_BACKUP_DIR=backups
NETBACKUP_LOG_FILE=logs/netbackup.log
NETBACKUP_RETENTION_DAYS=30
# IANA timezone used for timestamps in the web UI (stored values remain UTC).
# Examples: America/Los_Angeles, America/New_York, UTC
NETBACKUP_TIMEZONE=America/Los_Angeles

# Web UI network bind (0.0.0.0 = all interfaces; use 127.0.0.1 for localhost only)
NETBACKUP_WEB_HOST=0.0.0.0
NETBACKUP_WEB_PORT=8000

# Web UI authentication (required when exposed on the network)
NETBACKUP_WEB_USERNAME=
NETBACKUP_WEB_PASSWORD=

# Default fallback credentials used when a device-specific env var is not set.
NETBACKUP_DEFAULT_API_KEY=
NETBACKUP_DEFAULT_USERNAME=
NETBACKUP_DEFAULT_PASSWORD=

# Per-device secrets follow the naming convention:
#   <DEVICE_NAME>_<SECRET_TYPE>
# Device names are upper-cased, and any non-alphanumeric character becomes an underscore.
# Examples:
#   panorama-01  -> PANORAMA_01_API_KEY
#   firewall-01    -> FIREWALL_01_API_KEY
#   switch-01      -> SWITCH_01_USERNAME, SWITCH_01_PASSWORD
PANORAMA_01_API_KEY=
FIREWALL_01_API_KEY=
SWITCH_01_USERNAME=
SWITCH_01_PASSWORD=

# You can also keep legacy global names if you prefer, but per-device names are recommended
# because they scale to many devices without collisions.
